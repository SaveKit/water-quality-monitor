# AWS Connection Configuration
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID_FOR_LOCAL_TESTING
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY_FOR_LOCAL_TESTING

# DynamoDB Tables (Must match backend/.env and AWS deployment)
DYNAMODB_TABLE_SENSOR=WaterQualityData
DYNAMODB_TABLE_FORECAST=ForecastResults
DYNAMODB_TABLE_ALERTS=AlertHistory

# Telegram Notification Settings (For Plateau Alerts)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID
